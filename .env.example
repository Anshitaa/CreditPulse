# CreditPulse Environment Variables
# Copy to .env and fill in values

# Database (PostgreSQL on port 5435 to avoid Mac conflicts)
DATABASE_URL=postgresql://creditpulse:creditpulse@localhost:5435/creditpulse

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# MLflow (port 5001 — port 5000 taken by macOS AirPlay)
MLFLOW_TRACKING_URI=http://localhost:5001

# LLM — set at least one (Gemini Flash is free)
GEMINI_API_KEY=your-gemini-api-key
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Redis (Feast online store)
REDIS_URL=redis://localhost:6379

# Java for PySpark (Anaconda OpenJDK)
JAVA_HOME=/opt/anaconda3
JDBC_JAR=/Users/anshita/Desktop/CreditPulse/spark/jars/postgresql-42.7.3.jar
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
